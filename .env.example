# ══════════════════════════════════════════════════════════════
# OpenAutonomyX Platform — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Domain ───────────────────────────────────────────────────
DOMAIN=openautonomyx.com

# ── SMTP (Stalwart Mail) ─────────────────────────────────────
SMTP_HOST=mail.openautonomyx.com
SMTP_PORT=5870
SMTP_USER=noreply
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@openautonomyx.com

# ── Shared Infrastructure ────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
REDIS_URL=redis://shared_redis:6379

# ── Billing (Lago) ───────────────────────────────────────────
LAGO_SECRET_KEY_BASE=changeme_generate_with_openssl_rand_hex_64
LAGO_RSA_PRIVATE_KEY=changeme_generate_with_openssl_genrsa_2048_base64
LAGO_ENCRYPTION_PRIMARY_KEY=changeme32chars
LAGO_ENCRYPTION_DETERMINISTIC_KEY=changeme32chars
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=changeme32chars

# ── Error Tracking (GlitchTip) ───────────────────────────────
GLITCHTIP_SECRET_KEY=changeme

# ── Notifications (Novu) ─────────────────────────────────────
NOVU_JWT_SECRET=changeme
NOVU_ENCRYPTION_KEY=changeme

# ── Scheduling (Cal.com) ─────────────────────────────────────
CALCOM_NEXTAUTH_SECRET=changeme
CALCOM_ENCRYPTION_KEY=changeme

# ── Social (Postiz) ──────────────────────────────────────────
POSTIZ_JWT_SECRET=changeme

# ── Docs (OnlyOffice) ────────────────────────────────────────
ONLYOFFICE_JWT_SECRET=changeme

# ── Mail (Stalwart) ──────────────────────────────────────────
STALWART_HOSTNAME=mail.openautonomyx.com
STALWART_ADMIN_SECRET=changeme
