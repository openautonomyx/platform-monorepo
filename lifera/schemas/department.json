{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/department.json",
  "title": "Department",
  "description": "Department/team within a tenant (Schema.org Organization)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "code": { "type": "string" },
    "type": { "type": "string", "enum": ["division", "department", "team", "unit"] },
    "parentOrganizationId": { "type": "string", "format": "uuid" },
    "parentOrganization": { "type": "string" },
    "member": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "numberOfEmployees": {
      "type": "object",
      "properties": {
        "value": { "type": "integer" },
        "unitText": { "type": "string", "enum": ["EMPLOYEE"] }
      }
    },
    "areaServed": { "type": "string" },
    "managerId": { "type": "string", "format": "uuid" },
    "manager": { "type": "string" },
    "headcountTarget": { "type": "integer" },
    "logo": { "type": "string", "format": "uri" },
    "url": { "type": "string", "format": "uri" },
    "email": { "type": "string", "format": "email" },
    "telephone": { "type": "string" },
    "faxNumber": { "type": "string" },
    "address": {
      "type": "object",
      "properties": {
        "streetAddress": { "type": "string" },
        "addressLocality": { "type": "string" },
        "addressRegion": { "type": "string" },
        "postalCode": { "type": "string" },
        "addressCountry": { "type": "string" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name"],
  "additionalProperties": true
}