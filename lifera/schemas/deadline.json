{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/deadline.json",
  "title": "Deadline",
  "description": "A time-bound commitment with due date (Schema.org Event)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "startDate": { "type": "string", "format": "date-time" },
    "endDate": { "type": "string", "format": "date-time" },
    "eventStatus": {
      "type": "string",
      "enum": ["EventScheduled", "EventInProgress", "EventCompleted", "EventCancelled", "Postponed", "Rescheduled"]
    },
    "parentType": {
      "type": "string",
      "enum": ["task", "milestone", "project"]
    },
    "parentId": { "type": "string", "format": "uuid" },
    "organizer": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "location": { "type": "string" },
    "notifyEmployeeId": { "type": "string", "format": "uuid" },
    "notifyEmployee": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["upcoming", "due", "breached", "completed", "extended"]
    },
    "reminderSent": { "type": "boolean" },
    "escalationRuleId": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name", "startDate"],
  "additionalProperties": true
}