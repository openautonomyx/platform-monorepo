{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/employee.json",
  "title": "Employee",
  "description": "A human user within a tenant (Schema.org Person)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "email": { "type": "string", "format": "email" },
    "name": { "type": "string", "minLength": 1 },
    "givenName": { "type": "string" },
    "familyName": { "type": "string" },
    "additionalName": { "type": "string" },
    "honorificPrefix": { "type": "string" },
    "honorificSuffix": { "type": "string" },
    "jobTitle": { "type": "string" },
    "description": { "type": "string" },
    "address": {
      "type": "object",
      "properties": {
        "streetAddress": { "type": "string" },
        "addressLocality": { "type": "string" },
        "addressRegion": { "type": "string" },
        "postalCode": { "type": "string" },
        "addressCountry": { "type": "string" }
      }
    },
    "telephone": { "type": "string" },
    "birthDate": { "type": "string", "format": "date" },
    "birthPlace": { "type": "string" },
    "deathDate": { "type": "string", "format": "date" },
    "nationality": { "type": "string" },
    "worksFor": {
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "organizationName": { "type": "string" }
      }
    },
    "departmentId": { "type": "string", "format": "uuid" },
    "jobTitleId": { "type": "string", "format": "uuid" },
    "seniority": {
      "type": "string",
      "enum": ["junior", "mid", "senior", "lead", "principal"]
    },
    "managerId": { "type": "string", "format": "uuid" },
    "hireDate": { "type": "string", "format": "date" },
    "terminationDate": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "suspended"]
    },
    "photo": { "type": "string", "format": "uri" },
    "sameAs": { "type": "string", "format": "uri" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "email", "name"],
  "additionalProperties": true
}