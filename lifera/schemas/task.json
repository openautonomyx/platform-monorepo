{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/task.json",
  "title": "Task",
  "description": "A work item/task (Schema.org Action)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "blocked", "completed", "cancelled"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "taskType": {
      "type": "string",
      "enum": ["action", "review", "approval", "decision"]
    },
    "parentType": {
      "type": "string",
      "enum": ["project", "group", "task", "workflow"]
    },
    "parentId": { "type": "string", "format": "uuid" },
    "agent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "object": { "type": "string" },
    "instrument": { "type": "string" },
    "target": { "type": "string" },
    "result": { "type": "string" },
    "assigneeId": { "type": "string", "format": "uuid" },
    "assignee": { "type": "string" },
    "assigneeAgentId": { "type": "string", "format": "uuid" },
    "assigneeAgent": { "type": "string" },
    "dueDate": { "type": "string", "format": "date-time" },
    "estimatedHours": { "type": "number" },
    "actualHours": { "type": "number" },
    "createdBy": { "type": "string", "format": "uuid" },
    "completedAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name", "status"],
  "additionalProperties": true
}