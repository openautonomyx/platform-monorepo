{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/product.json",
  "title": "Product",
  "description": "A product/service line containing projects (Schema.org Product)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "brand": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string", "format": "uri" }
      }
    },
    "category": { "type": "string" },
    "manufacturer": { "type": "string" },
    "model": { "type": "string" },
    "sku": { "type": "string" },
    "gtin": { "type": "string" },
    "mpn": { "type": "string" },
    "logo": { "type": "string", "format": "uri" },
    "image": { "type": "string", "format": "uri" },
    "url": { "type": "string", "format": "uri" },
    "ownerId": { "type": "string", "format": "uuid" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived", "deprecated"]
    },
    "offers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price": { "type": "number" },
          "priceCurrency": { "type": "string" },
          "availability": { "type": "string" },
          "validFrom": { "type": "string", "format": "date-time" },
          "validThrough": { "type": "string", "format": "date-time" }
        }
      }
    },
    "aggregateRating": {
      "type": "object",
      "properties": {
        "ratingValue": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "bestRating": { "type": "number" },
        "worstRating": { "type": "number" }
      }
    },
    "review": { "type": "array", "items": { "type": "object" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name"],
  "additionalProperties": true
}