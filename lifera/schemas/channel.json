{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/channel.json",
  "title": "Channel",
  "description": "A discussion channel (Schema.org DiscussionForum)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "groupId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["chat", "announcement", "threaded", "support"]
    },
    "privacy": {
      "type": "string",
      "enum": ["public", "private", "direct"]
    },
    "ownerId": { "type": "string", "format": "uuid" },
    "owner": { "type": "string" },
    "about": { "type": "string" },
    "keywords": { "type": "string" },
    "numMembers": { "type": "integer" },
    "abstract": { "type": "string" },
    "image": { "type": "string", "format": "uri" },
    "url": { "type": "string", "format": "uri" },
    "status": {
      "type": "string",
      "enum": ["active", "archived"]
    },
    "runtimeId": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name", "type"],
  "additionalProperties": true
}