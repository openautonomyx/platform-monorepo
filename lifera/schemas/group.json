{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/group.json",
  "title": "Group",
  "description": "A collaboration container (Schema.org Organization)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["team", "project", "department", "company", "external"]
    },
    "privacy": {
      "type": "string",
      "enum": ["public", "private", "internal"]
    },
    "parentGroupId": { "type": "string", "format": "uuid" },
    "parentOrganization": { "type": "string" },
    "ownerId": { "type": "string", "format": "uuid" },
    "owner": { "type": "string" },
    "member": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "numberOfMembers": { "type": "integer" },
    "logo": { "type": "string", "format": "uri" },
    "image": { "type": "string", "format": "uri" },
    "url": { "type": "string", "format": "uri" },
    "email": { "type": "string", "format": "email" },
    "status": {
      "type": "string",
      "enum": ["active", "archived"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name"],
  "additionalProperties": true
}