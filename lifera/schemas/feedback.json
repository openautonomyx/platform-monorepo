{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/feedback.json",
  "title": "Feedback",
  "description": "User feedback on products (Schema.org Review)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "itemReviewed": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "reviewRating": {
      "type": "object",
      "properties": {
        "ratingValue": { "type": "integer" },
        "bestRating": { "type": "integer" },
        "worstRating": { "type": "integer" }
      }
    },
    "reviewBody": { "type": "string" },
    "name": { "type": "string" },
    "author": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "datePublished": { "type": "string", "format": "date-time" },
    "dateCreated": { "type": "string", "format": "date-time" },
    "category": {
      "type": "string",
      "enum": ["product", "feature", "process", "other"]
    },
    "sentiment": {
      "type": "string",
      "enum": ["positive", "neutral", "negative"]
    },
    "linkedType": {
      "type": "string",
      "enum": ["product", "project", "channel", "platform"]
    },
    "linkedId": { "type": "string", "format": "uuid" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "acknowledged", "in_progress", "resolved", "closed"]
    },
    "aggregateRating": {
      "type": "object",
      "properties": {
        "ratingValue": { "type": "number" },
        "reviewCount": { "type": "integer" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "itemReviewed", "author"],
  "additionalProperties": true
}