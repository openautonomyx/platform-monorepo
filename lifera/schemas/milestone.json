{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomyx.com/schemas/milestone.json",
  "title": "Milestone",
  "description": "A checkpoint in project/workflow (Schema.org Event)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "startDate": { "type": "string", "format": "date-time" },
    "endDate": { "type": "string", "format": "date-time" },
    "eventStatus": {
      "type": "string",
      "enum": ["EventScheduled", "EventInProgress", "EventCompleted", "EventCancelled"]
    },
    "parentType": {
      "type": "string",
      "enum": ["project", "workflow"]
    },
    "parentId": { "type": "string", "format": "uuid" },
    "sequenceOrder": { "type": "integer" },
    "location": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "achieved", "at_risk", "missed"]
    },
    "achievedBy": { "type": "string", "format": "uuid" },
    "achievedAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["tenantId", "name", "startDate"],
  "additionalProperties": true
}