<?xml version="1.0" encoding="UTF-8"?>
<root>
    <dynamic-element name="productId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Product</value></meta-data>
    </dynamic-element>
    <dynamic-element name="description" type="text_area" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Description</value></meta-data>
    </dynamic-element>
    <dynamic-element name="ownerId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Owner (User ID)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="startDate" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Start Date</value></meta-data>
    </dynamic-element>
    <dynamic-element name="endDate" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">End Date</value></meta-data>
    </dynamic-element>
    <dynamic-element name="budget" type="number" index-type="number" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Budget</value></meta-data>
    </dynamic-element>
    <dynamic-element name="status" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Status</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">planning|Planning</value>
            <value language-id="en_US">active|Active</value>
            <value language-id="en_US">on_hold|On Hold</value>
            <value language-id="en_US">completed|Completed</value>
            <value language-id="en_US">archived|Archived</value>
        </meta-data>
    </dynamic-element>
</root>