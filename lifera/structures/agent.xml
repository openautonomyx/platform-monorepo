<?xml version="1.0" encoding="UTF-8"?>
<root>
    <dynamic-element name="name" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Agent Name</value></meta-data>
    </dynamic-element>
    <dynamic-element name="agentType" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Agent Type</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">human_facing|Human-Facing</value>
            <value language-id="en_US">task_worker|Task Worker</value>
            <value language-id="en_US">hybrid|Hybrid</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="primaryEmployeeId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Primary Employee (User ID)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="capabilities" type="text_area" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Capabilities (JSON)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="runtimeConfig" type="text_area" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Runtime Config (JSON)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="status" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Status</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">Active|Active</value>
            <value language-id="en_US">Inactive|Inactive</value>
            <value language-id="en_US">Suspended|Suspended</value>
        </meta-data>
    </dynamic-element>
</root>