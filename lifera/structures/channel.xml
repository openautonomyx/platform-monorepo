<?xml version="1.0" encoding="UTF-8"?>
<root>
    <dynamic-element name="groupId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Group</value></meta-data>
    </dynamic-element>
    <dynamic-element name="type" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Channel Type</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">chat|Chat</value>
            <value language-id="en_US">announcement|Announcement</value>
            <value language-id="en_US">threaded|Threaded</value>
            <value language-id="en_US">support|Support</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="privacy" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Privacy</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">public|Public</value>
            <value language-id="en_US">private|Private</value>
            <value language-id="en_US">direct|Direct</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="ownerId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Owner (User ID)</value></meta-data>
    </dynamic-element>
</root>