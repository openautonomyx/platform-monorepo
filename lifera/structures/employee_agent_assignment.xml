<?xml version="1.0" encoding="UTF-8"?>
<root>
    <dynamic-element name="employeeId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Employee (User ID)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="agentId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Agent ID</value></meta-data>
    </dynamic-element>
    <dynamic-element name="assignmentType" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Assignment Type</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">primary|Primary</value>
            <value language-id="en_US">secondary|Secondary</value>
            <value language-id="en_US">temporary|Temporary</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="accessLevel" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Access Level</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">full|Full</value>
            <value language-id="en_US">limited|Limited</value>
            <value language-id="en_US">restricted|Restricted</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="effectiveFrom" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Effective From</value></meta-data>
    </dynamic-element>
    <dynamic-element name="effectiveTo" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Effective To</value></meta-data>
    </dynamic-element>
</root>