<?xml version="1.0" encoding="UTF-8"?>
<root>
    <!-- EXTENDS LIFERAY USER - custom fields only -->
    <dynamic-element name="departmentId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Department (Org ID)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="jobTitleId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Job Title ID</value></meta-data>
    </dynamic-element>
    <dynamic-element name="seniority" type="select" index-type="keyword" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Seniority</value></meta-data>
        <meta-data index-key="optionLabels">
            <value language-id="en_US">Junior|Junior</value>
            <value language-id="en_US">Mid|Mid</value>
            <value language-id="en_US">Senior|Senior</value>
            <value language-id="en_US">Lead|Lead</value>
            <value language-id="en_US">Principal|Principal</value>
        </meta-data>
    </dynamic-element>
    <dynamic-element name="managerId" type="text" index-type="text" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Manager (User ID)</value></meta-data>
    </dynamic-element>
    <dynamic-element name="hireDate" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Hire Date</value></meta-data>
    </dynamic-element>
    <dynamic-element name="terminationDate" type="date" index-type="date" repeat="false">
        <meta-data index-key="label"><value language-id="en_US">Termination Date</value></meta-data>
    </dynamic-element>
</root>